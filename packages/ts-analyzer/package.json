{
  "name": "@rustex/ts-analyzer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "esbuild src/analyze.ts --bundle --minify --platform=node --format=cjs --target=node20 --outfile=dist/analyze.cjs",
    "analyze": "node dist/analyze.cjs",
    "check": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "effect": "^3.21.0",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "esbuild": "^0.25.11"
  }
}
